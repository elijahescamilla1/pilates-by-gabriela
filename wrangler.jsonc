{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pilates-by-gabriela",
  "compatibility_date": "2026-07-13",
  "routes": [
    { "pattern": "pilatesbygabby.com", "custom_domain": true },
    { "pattern": "www.pilatesbygabby.com", "custom_domain": true }
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
